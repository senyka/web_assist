FROM python:3.11-slim

WORKDIR /app

# Системные зависимости
RUN apt-get update && apt-get install -y \
    libldap2-dev libsasl2-dev python3-dev gcc curl \
    && rm -rf /var/lib/apt/lists/*

# Python зависимости
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip
RUN pip install --no-cache-dir -r requirements.txt

# Приложение
COPY . .

# Папка для БД
RUN mkdir -p /app/data

EXPOSE 5443

# Запуск приложения с оптимальными настройками для production
# workers: 2-4 для CPU-bound LLM задач, или $(nproc) для general purpose
CMD ["gunicorn", "--bind", "0.0.0.0:5443", "--workers", "4", "--threads", "2", "--timeout", "180", "--keep-alive", "5", "app:app"]
